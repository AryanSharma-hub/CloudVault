<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
</head>
<body class="cv-auth-body">
  <div class="cv-auth-wrapper">
    <div class="cv-auth-card cv-auth-card-wide">
      <div class="text-center mb-4">
        <span class="cv-brand-icon cv-brand-icon-lg"><i class="bi bi-cloud-fill"></i></span>
        <h1 class="cv-auth-title mt-3">Create your account</h1>
        <p class="text-muted">Start storing your files securely, for free</p>
      </div>

      <% if (errors && errors.length) { %>
        <div class="alert alert-danger cv-alert" role="alert">
          <ul class="mb-0 ps-3">
            <% errors.forEach(function(err) { %>
              <li><%= err %></li>
            <% }); %>
          </ul>
        </div>
      <% } %>

      <form action="/register" method="POST" novalidate>
        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label">First Name</label>
            <div class="input-group cv-input-group">
              <span class="input-group-text"><i class="bi bi-person"></i></span>
              <input type="text" name="firstName" class="form-control" value="<%= formData.firstName || '' %>" placeholder="Jane" required />
            </div>
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label">Last Name</label>
            <div class="input-group cv-input-group">
              <span class="input-group-text"><i class="bi bi-person"></i></span>
              <input type="text" name="lastName" class="form-control" value="<%= formData.lastName || '' %>" placeholder="Doe" required />
            </div>
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label">Email address</label>
          <div class="input-group cv-input-group">
            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
            <input type="email" name="email" class="form-control" value="<%= formData.email || '' %>" placeholder="you@example.com" required />
          </div>
        </div>

        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label">Password</label>
            <div class="input-group cv-input-group">
              <span class="input-group-text"><i class="bi bi-lock"></i></span>
              <input type="password" name="password" class="form-control" placeholder="At least 6 characters" required />
            </div>
          </div>
          <div class="col-md-6 mb-4">
            <label class="form-label">Confirm Password</label>
            <div class="input-group cv-input-group">
              <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
              <input type="password" name="confirmPassword" class="form-control" placeholder="Repeat password" required />
            </div>
          </div>
        </div>

        <button type="submit" class="btn cv-btn-primary w-100 py-2">
          <i class="bi bi-person-plus me-1"></i> Create Account
        </button>
      </form>

      <p class="text-center text-muted mt-4 mb-0">
        Already have an account? <a href="/login" class="cv-link">Log in</a>
      </p>
    </div>
  </div>
  <%- include('../partials/scripts') %>
</body>
</html>
