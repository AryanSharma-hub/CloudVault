<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body class="cv-app-body">
  <%- include('partials/navbar') %>

  <main class="container-fluid px-4 py-4">
    <% if (flashSuccess) { %>
      <div class="alert alert-success cv-alert alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i><%= flashSuccess %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>
    <% if (flashError) { %>
      <div class="alert alert-danger cv-alert alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i><%= flashError %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
      <div>
        <h2 class="cv-page-title mb-1">Welcome back, <%= user.firstName %> 👋</h2>
        <p class="text-muted mb-0">Here's what's happening with your storage today.</p>
      </div>
      <button class="btn cv-btn-primary mt-3 mt-md-0" data-bs-toggle="modal" data-bs-target="#uploadModal">
        <i class="bi bi-cloud-upload-fill me-1"></i> Upload File
      </button>
    </div>

    <div class="row g-4 mb-4">
      <div class="col-md-4">
        <div class="cv-stat-card cv-glass">
          <div class="cv-stat-icon cv-stat-icon-blue"><i class="bi bi-files"></i></div>
          <div>
            <div class="cv-stat-value"><%= stats.totalFiles %></div>
            <div class="cv-stat-label">Total Files</div>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="cv-stat-card cv-glass">
          <div class="cv-stat-icon cv-stat-icon-purple"><i class="bi bi-hdd-fill"></i></div>
          <div>
            <div class="cv-stat-value"><%= stats.totalSizeFormatted %></div>
            <div class="cv-stat-label">Storage Used</div>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="cv-stat-card cv-glass">
          <div class="cv-stat-icon cv-stat-icon-green"><i class="bi bi-download"></i></div>
          <div>
            <div class="cv-stat-value"><%= stats.totalDownloads %></div>
            <div class="cv-stat-label">Total Downloads</div>
          </div>
        </div>
      </div>
    </div>

    <div class="cv-glass cv-panel">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Recent Uploads</h5>
        <a href="/files" class="cv-link small">View all files <i class="bi bi-arrow-right"></i></a>
      </div>

      <% if (recentFiles.length === 0) { %>
        <div class="cv-empty-state">
          <i class="bi bi-cloud-arrow-up display-4"></i>
          <p class="mt-3 mb-0">No files yet. Upload your first file to get started!</p>
        </div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table cv-table align-middle mb-0">
            <thead>
              <tr>
                <th>File</th>
                <th>Type</th>
                <th>Size</th>
                <th>Uploaded</th>
                <th>Downloads</th>
                <th class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% recentFiles.forEach(function(file) { %>
                <tr>
                  <td>
                    <i class="bi <%= file.icon %> fs-5 me-2"></i><%= file.originalName %>
                  </td>
                  <td><span class="badge cv-badge"><%= file.fileType %></span></td>
                  <td><%= file.sizeFormatted %></td>
                  <td><%= file.uploadedAtFormatted %></td>
                  <td><%= file.downloadCount %></td>
                  <td class="text-end">
                    <a href="/files/<%= file.id %>/download" class="btn btn-sm cv-btn-icon" title="Download"><i class="bi bi-download"></i></a>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </main>

  <!-- Upload Modal -->
  <div class="modal fade" id="uploadModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content cv-modal">
        <form action="/files/upload" method="POST" enctype="multipart/form-data">
          <div class="modal-header border-0">
            <h5 class="modal-title"><i class="bi bi-cloud-upload-fill me-2"></i>Upload a File</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body">
            <div class="cv-dropzone" id="dropzone">
              <i class="bi bi-cloud-arrow-up display-4"></i>
              <p class="mb-1 mt-2">Drag & drop or click to browse</p>
              <p class="text-muted small mb-0">PDF, Images, ZIP, TXT, DOCX, PPTX — up to 50MB</p>
              <input type="file" name="file" id="fileInput" class="form-control mt-3" required
                accept=".pdf,.png,.jpg,.jpeg,.gif,.webp,.zip,.txt,.docx,.doc,.pptx,.ppt" />
            </div>
            <div id="fileNamePreview" class="mt-2 small text-muted"></div>
          </div>
          <div class="modal-footer border-0">
            <button type="button" class="btn cv-btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn cv-btn-primary"><i class="bi bi-upload me-1"></i> Upload</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <%- include('partials/scripts') %>
  <script src="/js/dashboard.js"></script>
</body>
</html>
